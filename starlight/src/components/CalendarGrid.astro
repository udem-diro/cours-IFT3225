---
/**
 * CalendarGrid.astro — Grille-calendrier pleine page.
 * Affiche les jours ouvrables du mois avec les séances
 * comme cellules cliquables.
 *
 * Props :
 *   sessions — métadonnées des séances depuis la collection
 *   month    — mois à afficher (1-12)
 *   year     — année
 */

interface SessionMeta {
  slug: string;
  numero: number;
  title: string;
  date: string;
  tags: string[];
  summary?: string;
}

interface Props {
  sessions: SessionMeta[];
  month: number;
  year: number;
}

const { sessions, month, year } = Astro.props;

const today = new Date();
const todayStr = today.toISOString().slice(0, 10);

// Jours du mois
const daysInMonth = new Date(year, month, 0).getDate();
// Jour de la semaine du 1er (0=dim, 1=lun…)
const firstDow = new Date(year, month - 1, 1).getDay();

// Noms des jours ouvrables
const dayNames = ['lun.', 'mar.', 'mer.', 'jeu.', 'ven.'];

// Construire la grille : semaines × 5 jours ouvrables
type CellData = {
  day: number;
  dateStr: string;
  session: SessionMeta | null;
  isToday: boolean;
  isPast: boolean;
} | null;

const weeks: CellData[][] = [];
let currentWeek: CellData[] = [];

// Remplir les cellules vides avant le 1er
// firstDow: 0=dim → pas de cellule lun-ven
// 1=lun → 0 vides, 2=mar → 1 vide, etc.
const mondayOffset = firstDow === 0 ? 5 : firstDow - 1;
for (let i = 0; i < Math.min(mondayOffset, 5); i++) {
  currentWeek.push(null);
}

for (let d = 1; d <= daysInMonth; d++) {
  const dow = new Date(year, month - 1, d).getDay();
  // Sauter sam (6) et dim (0)
  if (dow === 0 || dow === 6) continue;

  const dateStr = `${year}-${String(month).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
  const session = sessions.find((s) => s.date === dateStr) ?? null;

  currentWeek.push({
    day: d,
    dateStr,
    session,
    isToday: dateStr === todayStr,
    isPast: dateStr < todayStr,
  });

  if (currentWeek.length === 5) {
    weeks.push(currentWeek);
    currentWeek = [];
  }
}

// Dernière semaine incomplète
if (currentWeek.length > 0) {
  while (currentWeek.length < 5) currentWeek.push(null);
  weeks.push(currentWeek);
}

const monthName = new Date(year, month - 1, 1)
  .toLocaleDateString('fr-CA', { month: 'long', year: 'numeric' });
---

<section class="cal" aria-label={`Calendrier ${monthName}`}>
  <div class="cal__header-row">
    {dayNames.map((name) => (
      <div class="cal__day-name">{name}</div>
    ))}
  </div>

  {weeks.map((week) => (
    <div class="cal__week">
      {week.map((cell) =>
        cell === null ? (
          <div class="cal__cell cal__cell--empty" />
        ) : cell.session ? (
          <a
            class:list={[
              'cal__cell',
              'cal__cell--session',
              { 'cal__cell--today': cell.isToday },
              { 'cal__cell--past': cell.isPast },
            ]}
            href={`/cours/${cell.session.slug}/`}
          >
            <span class="cal__day-num">{cell.day}</span>
            <span class="cal__title">{cell.session.title}</span>
            {cell.session.summary && (
              <span class="cal__summary">{cell.session.summary}</span>
            )}
            <span class="cal__tags">
              {cell.session.tags.map((t) => (
                <span class={`cal__tag cal__tag--${t}`}>{t}</span>
              ))}
            </span>
          </a>
        ) : (
          <div
            class:list={[
              'cal__cell',
              { 'cal__cell--today': cell.isToday },
              { 'cal__cell--past': cell.isPast },
            ]}
          >
            <span class="cal__day-num">{cell.day}</span>
          </div>
        )
      )}
    </div>
  ))}
</section>

<style>
  .cal {
    width: 100%;
  }

  .cal__header-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 6px;
    margin-bottom: var(--space-2);
  }

  .cal__day-name {
    text-align: center;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--c-text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: var(--space-1) 0;
  }

  .cal__week {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 6px;
    margin-bottom: 6px;
  }

  .cal__cell {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-md);
    padding: var(--space-3);
    min-height: 100px;
    position: relative;
    transition:
      border-color var(--dur-fast) ease,
      box-shadow var(--dur-fast) ease;
  }

  .cal__cell--empty {
    background: transparent;
    border-color: transparent;
  }

  .cal__cell--past {
    opacity: 0.5;
  }

  .cal__cell--today {
    border-color: var(--c-accent);
    border-width: 2px;
    opacity: 1;
  }

  .cal__cell--session {
    display: flex;
    flex-direction: column;
    gap: 4px;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }

  .cal__cell--session:hover {
    border-color: var(--c-accent-mid);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }

  .cal__day-num {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--c-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .cal__cell--today .cal__day-num {
    color: var(--c-accent);
    font-weight: 600;
  }

  .cal__title {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--c-text);
    line-height: 1.3;
  }

  .cal__summary {
    font-size: 11px;
    color: var(--c-text-subtle);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cal__tags {
    display: flex;
    gap: 4px;
    margin-top: auto;
    flex-wrap: wrap;
  }

  .cal__tag {
    font-size: 10px;
    font-weight: 500;
    padding: 2px 7px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .cal__tag--cours  { background: var(--c-cours-bg); color: var(--c-cours); }
  .cal__tag--labo   { background: var(--c-labo-bg);  color: var(--c-labo); }
  .cal__tag--devoir { background: var(--c-devoir-bg); color: var(--c-devoir); }
  .cal__tag--examen { background: var(--c-examen-bg); color: var(--c-examen); }

  @media (max-width: 768px) {
    .cal__cell { min-height: 80px; padding: var(--space-2); }
    .cal__title { font-size: 12px; }
    .cal__summary { display: none; }
  }

  @media (max-width: 480px) {
    .cal__week { grid-template-columns: 1fr; }
    .cal__header-row { display: none; }
    .cal__cell { min-height: auto; }
    .cal__cell--empty { display: none; }
  }
</style>
