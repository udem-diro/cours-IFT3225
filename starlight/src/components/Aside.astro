    hue: '220',
    bgLight: 'hsl(220 60% 96%)',
    bgDark: 'hsl(220 30% 14%)',
    borderLight: 'hsl(220 60% 65%)',
    borderDark: 'hsl(220 50% 45%)',
    iconColorLight: 'hsl(220 60% 50%)',
    iconColorDark: 'hsl(220 60% 65%)',
  },
  tip: {
    label: 'Astuce',
    icon: 'lightbulb',
    hue: '150',
    bgLight: 'hsl(150 50% 95%)',
    bgDark: 'hsl(150 25% 13%)',
    borderLight: 'hsl(150 50% 45%)',
    borderDark: 'hsl(150 40% 38%)',
    iconColorLight: 'hsl(150 55% 38%)',
    iconColorDark: 'hsl(150 50% 55%)',
  },
  caution: {
    label: 'Attention',
    icon: 'warning',
    hue: '40',
    bgLight: 'hsl(40 80% 95%)',
    bgDark: 'hsl(40 30% 13%)',
    borderLight: 'hsl(40 80% 50%)',
    borderDark: 'hsl(40 60% 40%)',
    iconColorLight: 'hsl(40 80% 40%)',
    iconColorDark: 'hsl(40 70% 55%)',
  },
  danger: {
    label: 'Danger',
    icon: 'error',
    hue: '0',
    bgLight: 'hsl(0 70% 96%)',
    bgDark: 'hsl(0 30% 14%)',
    borderLight: 'hsl(0 65% 55%)',
    borderDark: 'hsl(0 50% 42%)',
    iconColorLight: 'hsl(0 65% 48%)',
    iconColorDark: 'hsl(0 60% 60%)',
  },

  /* — Pédagogiques — */
  prerequis: {
    label: 'Prérequis',
    icon: 'prerequis',
    hue: '250',
    bgLight: 'hsl(250 50% 96%)',
    bgDark: 'hsl(250 25% 14%)',
    borderLight: 'hsl(250 50% 60%)',
    borderDark: 'hsl(250 40% 45%)',
    iconColorLight: 'hsl(250 50% 50%)',
    iconColorDark: 'hsl(250 50% 65%)',
  },
  definition: {
    label: 'Définition',
    icon: 'definition',
    hue: '280',
    bgLight: 'hsl(280 45% 96%)',
    bgDark: 'hsl(280 22% 14%)',
    borderLight: 'hsl(280 45% 58%)',
    borderDark: 'hsl(280 35% 45%)',
    iconColorLight: 'hsl(280 45% 46%)',
    iconColorDark: 'hsl(280 45% 65%)',
  },
  syntaxe: {
    label: 'Syntaxe',
    icon: 'syntaxe',
    hue: '195',
