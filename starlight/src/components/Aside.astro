const c = config[type] ?? config.note;
const displayTitle = title ?? c.label;

/* ── Icônes SVG (18×18 viewBox) ─────────────────────────────── */

const icons: Record<string, string> = {
  /* Natifs */
  info: `<path d="M9 1a8 8 0 1 0 0 16A8 8 0 0 0 9 1Zm.75 4.5v1.25h-1.5V5.5h1.5ZM8.25 8h1.5v4.5h-1.5V8Z" fill="currentColor"/>`,
  lightbulb: `<path d="M9 1.5a4.5 4.5 0 0 0-2.25 8.4V12a.75.75 0 0 0 .75.75h3a.75.75 0 0 0 .75-.75V9.9A4.502 4.502 0 0 0 9 1.5ZM7.5 14.25h3v.75a1.5 1.5 0 0 1-3 0v-.75Z" fill="currentColor"/>`,
  warning: `<path d="M8.13 2.25a1 1 0 0 1 1.74 0l6.5 11.25A1 1 0 0 1 15.5 15h-13a1 1 0 0 1-.87-1.5l6.5-11.25ZM9.75 7h-1.5v4h1.5V7Zm0 5.25h-1.5V13.5h1.5v-1.25Z" fill="currentColor"/>`,
  error: `<path d="M9 1a8 8 0 1 0 0 16A8 8 0 0 0 9 1Zm3.54 10.46-1.08 1.08L9 10.08l-2.46 2.46-1.08-1.08L7.92 9 5.46 6.54l1.08-1.08L9 7.92l2.46-2.46 1.08 1.08L10.08 9l2.46 2.46Z" fill="currentColor"/>`,

  /* Pédagogiques */
  prerequis: `<path d="M3 4.5A1.5 1.5 0 0 1 4.5 3h4.59a1.5 1.5 0 0 1 1.06.44l3.41 3.41a1.5 1.5 0 0 1 .44 1.06V13.5A1.5 1.5 0 0 1 12.5 15h-8A1.5 1.5 0 0 1 3 13.5v-9Zm6 0L4.5 4.5v9h8V8.5H9.5a.5.5 0 0 1-.5-.5V4.5Zm1.5 1.06 1.94 1.94H10.5V5.56Z" fill="currentColor"/><path d="M6 10.25h5v1.25H6z" fill="currentColor"/><path d="M6 7.75h2.25V9H6z" fill="currentColor"/>`,
  definition: `<path d="M3.5 2A1.5 1.5 0 0 0 2 3.5v11A1.5 1.5 0 0 0 3.5 16h10a1.5 1.5 0 0 0 1.5-1.5V5.121a1.5 1.5 0 0 0-.44-1.06L12.44 1.94A1.5 1.5 0 0 0 11.378 1.5H3.5ZM3.5 3.5h7v2.75a.75.75 0 0 0 .75.75H14v7.5H3.5v-11Zm3 4.75h5v1.25h-5V8.25Zm-1.5 0h1v1.25h-1V8.25Zm1.5 2.5h5V12h-5v-1.25Zm-1.5 0h1V12h-1v-1.25Z" fill="currentColor"/>`,
  syntaxe: `<path d="M5.854 4.146a.5.5 0 0 1 0 .708L3.207 7.5l2.647 2.646a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 0 1 .708 0Zm6.292 0a.5.5 0 0 0 0 .708L14.793 7.5l-2.647 2.646a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708 0ZM10.045 2.32a.5.5 0 0 1 .385.595l-2.5 11a.5.5 0 1 1-.975-.222l2.5-11a.5.5 0 0 1 .59-.374Z" fill="currentColor"/>`,
  erreur: `<path d="M9 1a8 8 0 1 0 0 16A8 8 0 0 0 9 1ZM4.562 13.438a6.5 6.5 0 0 1 8.876-8.876l-8.876 8.876Zm1.06 1.06 8.876-8.876a6.5 6.5 0 0 1-8.876 8.876Z" fill="currentColor"/>`,
  exemple: `<path d="M2.5 2a.5.5 0 0 0-.5.5v10a.5.5 0 0 0 .5.5H6v2.5a.5.5 0 0 0 .82.385L10.28 13H15.5a.5.5 0 0 0 .5-.5v-10a.5.5 0 0 0-.5-.5h-13ZM5 6.5h8V8H5V6.5Zm0 2.75h5v1.25H5V9.25Z" fill="currentColor"/>`,
  resultat: `<path d="M9 1a8 8 0 1 0 0 16A8 8 0 0 0 9 1Zm3.85 6.35-4.5 4.5a.5.5 0 0 1-.7 0l-2.5-2.5a.5.5 0 1 1 .7-.7L8 10.79l4.15-4.14a.5.5 0 0 1 .7.7Z" fill="currentColor"/>`,
  plusloin: `<path d="M9 1a8 8 0 1 0 0 16A8 8 0 0 0 9 1Zm-.5 4h1v4.793l2.854 2.853-.708.708L8.5 10.207V5Z" fill="currentColor"/><path d="M4.5 9a4.5 4.5 0 0 1 9 0" stroke="currentColor" stroke-width="1" fill="none"/><path d="M14 7.5l-.5 2-1.5-1.5" stroke="currentColor" stroke-width=".8" fill="none"/>`,
