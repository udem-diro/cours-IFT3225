const iconSvg = icons[c.icon] ?? icons.info;

/* ── ID unique pour le scope CSS ────────────────────────────── */
const uid = `aside-${Math.random().toString(36).slice(2, 8)}`;
---

<aside class={`aside aside--${type}`} id={uid} role="note" aria-label={displayTitle}>
  <div class="aside__header">
    <span class="aside__icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
        <Fragment set:html={iconSvg} />
      </svg>
    </span>
    <span class="aside__title">{displayTitle}</span>
  </div>
  <div class="aside__content">
    <slot />
  </div>
</aside>

<style define:vars={{
  bgLight: c.bgLight,
  bgDark: c.bgDark,
  borderLight: c.borderLight,
  borderDark: c.borderDark,
  iconColorLight: c.iconColorLight,
  iconColorDark: c.iconColorDark,
}}>
  .aside {
    --_bg: var(--bgLight);
    --_border: var(--borderLight);
    --_icon: var(--iconColorLight);

    position: relative;
    margin: 1.25rem 0;
    padding: 0;
    border-radius: 0.5rem;
    border-left: 3.5px solid var(--_border);
    background: var(--_bg);
    overflow: hidden;
    font-size: 1.3rem;
    line-height: 1.6;
  }

  /* Thème sombre — Starlight utilise [data-theme="dark"] */
  :global([data-theme='dark']) .aside,
  :global(.dark) .aside {
    --_bg: var(--bgDark);
    --_border: var(--borderDark);
    --_icon: var(--iconColorDark);
  }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .aside {
      --_bg: var(--bgDark);
      --_border: var(--borderDark);
      --_icon: var(--iconColorDark);
    }
  }

  .aside__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem 0.35rem;
    font-weight: 650;
    font-size: 1.2rem;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--_icon);
  }

  .aside__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--_icon);
  }

  .aside__title {
    color: var(--_icon);
  }

  .aside__content {
    padding: 0.15rem 1rem 0.85rem 1rem;
    color: var(--sl-color-text, inherit);
  }

  /* Espacement entre paragraphes dans le contenu */
  .aside__content :global(p) {
    margin: 0.4em 0;
  }

  .aside__content :global(p:first-child) {
    margin-top: 0;
  }

  .aside__content :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Code inline dans l'encadré */
  .aside__content :global(code) {
    font-size: 0.88em;
    padding: 0.15em 0.35em;
    border-radius: 0.25rem;
    background: rgba(0, 0, 0, 0.06);
  }

  :global([data-theme='dark']) .aside__content :global(code),
  :global(.dark) .aside__content :global(code) {
    background: rgba(255, 255, 255, 0.08);
  }

  /* Blocs de code dans l'encadré */
  .aside__content :global(pre) {
    margin: 0.6em 0;
    border-radius: 0.375rem;
  }

  /* Listes dans l'encadré */
  .aside__content :global(ul),
  .aside__content :global(ol) {
    margin: 0.4em 0;
    padding-left: 1.35em;
  }
</style>
