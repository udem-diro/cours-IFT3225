    iconColorDark: 'hsl(195 50% 58%)',
  },
  erreur: {
    label: 'Erreur commune',
    icon: 'erreur',
    hue: '15',
    bgLight: 'hsl(15 70% 96%)',
    bgDark: 'hsl(15 30% 13%)',
    borderLight: 'hsl(15 70% 55%)',
    borderDark: 'hsl(15 50% 42%)',
    iconColorLight: 'hsl(15 65% 45%)',
    iconColorDark: 'hsl(15 60% 60%)',
  },
  exemple: {
    label: 'Exemple',
    icon: 'exemple',
    hue: '35',
    bgLight: 'hsl(35 70% 95%)',
    bgDark: 'hsl(35 28% 13%)',
    borderLight: 'hsl(35 65% 52%)',
    borderDark: 'hsl(35 45% 40%)',
    iconColorLight: 'hsl(35 65% 42%)',
    iconColorDark: 'hsl(35 60% 58%)',
  },
  resultat: {
    label: 'Résultat attendu',
    icon: 'resultat',
    hue: '160',
    bgLight: 'hsl(160 45% 95%)',
    bgDark: 'hsl(160 22% 13%)',
    borderLight: 'hsl(160 50% 42%)',
    borderDark: 'hsl(160 38% 35%)',
    iconColorLight: 'hsl(160 50% 34%)',
    iconColorDark: 'hsl(160 45% 52%)',
  },
  plusloin: {
