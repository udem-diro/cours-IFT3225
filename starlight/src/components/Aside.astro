---
/**
 * Aside.astro — Encadré pédagogique pour sites de cours Astro Starlight
 *
 * Remplacement enrichi du <Aside> natif de Starlight.
 * Supporte les 4 types natifs + 7 types pédagogiques.
 *
 * Props :
 *   type  — Type d'encadré (voir liste ci-dessous)
 *   title — Titre personnalisé (optionnel, un défaut par type)
 *
 * Types natifs :     note · tip · caution · danger
 * Types cours :      prerequis · definition · syntaxe · erreur
 *                    exemple · resultat · plusloin
 *
 * Usage :
 *   <Aside type="definition" title="Variable">
 *     Un espace nommé en mémoire…
 *   </Aside>
 */

type AsideType =
  | 'note' | 'tip' | 'caution' | 'danger'
  | 'prerequis' | 'definition' | 'syntaxe' | 'erreur'
  | 'exemple' | 'resultat' | 'plusloin';

interface Props {
  type?: AsideType;
  title?: string;
}

const { type = 'note', title } = Astro.props;

/* ── Palette & config par type ──────────────────────────────── */

const config: Record<AsideType, {
  label: string;
  icon: string;
  hue: string;        /* Teinte HSL dominante */
  bgLight: string;
  bgDark: string;
  borderLight: string;
  borderDark: string;
  iconColorLight: string;
  iconColorDark: string;
