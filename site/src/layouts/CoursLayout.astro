<style>
@import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,700;1,9..144,400&family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap');

:root {
  --font-display: 'Fraunces', Georgia, serif;
  --font-body:    'DM Sans', system-ui, sans-serif;
  --font-mono:    'JetBrains Mono', 'Fira Code', monospace;
}

body {
  margin: 0;
  font-family: var(--font-body);
  font-size: var(--text-base);
  line-height: 1.65;
  color: var(--c-text);
  background: var(--c-bg);
  width: 100%;
  -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
  font-family: var(--font-display);
  font-weight: 500;
  line-height: 1.25;
  margin: 0;
}

code, pre {
  font-family: var(--font-mono);
}

a {
  color: var(--c-accent);
  text-decoration: none;
}
a:hover {
  text-decoration: underline;
}

  .cours-main {
    max-width: 80rem;
    margin: 0 auto;
    padding: var(--space-6) var(--space-6) var(--space-12);
  }

  .cours-header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--c-border);
  }

  .cours-header__tags {
    display: flex;
    gap: 6px;
    margin-bottom: var(--space-3);
  }

  .cours-header__tag {
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 3px 10px;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .cours-header__tag--cours  { background: var(--c-cours-bg); color: var(--c-cours); }
  .cours-header__tag--labo   { background: var(--c-labo-bg);  color: var(--c-labo); }
  .cours-header__tag--devoir { background: var(--c-devoir-bg); color: var(--c-devoir); }
  .cours-header__tag--examen { background: var(--c-examen-bg); color: var(--c-examen); }

  .cours-header__title {
    font-size: var(--text-2xl);
    font-family: var(--font-display);
    color: var(--c-text);
    margin-top: var(--space-2);
  }

  .cours-header__date {
    display: block;
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--c-text-muted);
  }

  /* ── Contenu ── */
  .cours-content {
    line-height: 1.75;
    position: relative; 
    overflow: visible
  }

  .cours-content :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
    color: var(--c-text);
  }

  .cours-content :global(h3) {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }

  .cours-content :global(p) {
    margin-bottom: var(--space-4);
  }

  .cours-content :global(ul),
  .cours-content :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: 1.5em;
  }

  .cours-content :global(li) {
    margin-bottom: var(--space-1);
  }

  .cours-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    padding: 0.15em 0.4em;
    border-radius: var(--radius-sm);
    background: var(--c-surface-alt);
  }

  .cours-content :global(pre) {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    background: var(--c-surface-alt);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    overflow-x: auto;
    margin-bottom: var(--space-4);
  }

  .cours-content :global(pre code) {
    padding: 0;
    background: none;
  }

  /* ── Navigation prev/next ── */
  .cours-nav {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--c-border);
  }

  .cours-nav__link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--c-border);
    text-decoration: none;
    transition: border-color var(--dur-fast) ease;
    max-width: 45%;
  }

  .cours-nav__link:hover {
    border-color: var(--c-accent-mid);
    text-decoration: none;
  }

  .cours-nav__link--next {
    margin-left: auto;
    text-align: right;
  }

  .cours-nav__arrow {
    font-size: var(--text-lg);
    color: var(--c-text-muted);
  }

  .cours-nav__label {
    display: block;
    font-size: var(--text-xs);
    color: var(--c-text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .cours-nav__title {
    display: block;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--c-text);
    margin-top: 2px;
  }

  @media (max-width: 640px) {
    .cours-main { padding: var(--space-4) var(--space-3) var(--space-8); }
    .cours-header__title { font-size: var(--text-xl); }
    .cours-nav { flex-direction: column; }
    .cours-nav__link { max-width: 100%; }
  }
</style>
