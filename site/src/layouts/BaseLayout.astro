---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
  title?: string;
  description?: string;
}
const { title = "IFT3225 — Technologies de l'internet", description = "Notes de cours, activités et projet." } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {/* Anti-FOUC : applique le thème avant le premier rendu */}
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem("theme");
          const sys = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
          document.documentElement.setAttribute("data-theme", saved || sys);
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
  </head>

  <body>
    <Sidebar />

    {/* Barre supérieure mobile : burger + thème */}
    <div class="topbar">
      <button class="topbar__burger" id="burger" aria-label="Ouvrir le menu">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18"></path>
        </svg>
      </button>
      <span class="topbar__sigle">IFT3225</span>
      <ThemeToggle />
    </div>

    <div class="scrim" id="scrim" aria-hidden="true"></div>

    <main class="shell">
      <slot />
    </main>

    {/* Bouton thème flottant sur desktop */}
    <div class="theme-float">
      <ThemeToggle />
    </div>

    <script>
      function initShell() {
        const burger = document.getElementById("burger");
        const sidebar = document.getElementById("sidebar");
        const scrim = document.getElementById("scrim");
        const toggle = () => {
          sidebar?.classList.toggle("open");
          scrim?.classList.toggle("show");
        };
        burger?.addEventListener("click", toggle);
        scrim?.addEventListener("click", toggle);
      }
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initShell);
      } else {
        initShell();
      }
      document.addEventListener("astro:page-load", initShell);
    </script>

    <style>
      .shell {
        margin-left: var(--nav-width);
        min-height: 100vh;
        padding: 3.5rem 3rem 6rem;
      }

      /* Topbar mobile */
      .topbar {
        display: none;
        position: sticky;
        top: 0;
        z-index: 40;
        align-items: center;
        gap: 12px;
        padding: 10px 16px;
        background: var(--c-surface);
        border-bottom: 1px solid var(--c-border);
      }
      .topbar__burger {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px; height: 38px;
        border: 1px solid var(--c-border);
        border-radius: var(--radius-sm);
        background: var(--c-surface);
        color: var(--c-text);
        cursor: pointer;
      }
      .topbar__sigle {
        font-family: var(--mono);
        font-weight: 700;
        font-size: 0.85rem;
        color: var(--c-accent);
        letter-spacing: 0.06em;
        margin-right: auto;
      }

      .scrim {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.4);
        z-index: 45;
        opacity: 0;
        transition: opacity 0.3s;
      }
      .scrim.show { opacity: 1; }

      .theme-float {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 60;
      }

      @media (max-width: 920px) {
        .shell { margin-left: 0; padding: 1.5rem 1.25rem 4rem; }
        .topbar { display: flex; }
        .scrim.show { display: block; }
        .theme-float { display: none; }
      }
    </style>
  </body>
</html>
