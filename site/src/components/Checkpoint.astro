---
/**
 * Checkpoint.astro
 *
 * Un point de contrôle de compréhension : une question, et une réponse
 * que l'étudiant révèle après avoir réfléchi. Sert à transformer la
 * lecture passive en lecture active à des moments charnières.
 *
 * Usage (dans MDX) :
 *   <Checkpoint question="Pourquoi ne versionne-t-on pas node_modules/ ?">
 *     Parce qu'il se régénère avec `npm install` à partir de `package.json`.
 *     Le versionner alourdit le dépôt de milliers de fichiers inutiles.
 *   </Checkpoint>
 *
 * Le slot par défaut contient la réponse (cachée jusqu'au clic).
 */

interface Props {
  question: string;
}
const { question } = Astro.props;
---

<details class="cp">
  <summary class="cp__q">
    <span class="cp__badge">Vérification</span>
    <span class="cp__qtext">{question}</span>
    <span class="cp__chevron" aria-hidden="true">▸</span>
  </summary>
  <div class="cp__answer">
    <slot />
  </div>
</details>

<style>
  .cp {
    margin: 1.8rem 0;
    border: 1px solid var(--sl-color-gray-5, #e2e0db);
    border-radius: 12px;
    background: var(--sl-color-bg, #fff);
    overflow: hidden;
  }
  .cp__q {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    cursor: pointer;
    user-select: none;
    list-style: none;
    transition: background 0.15s;
  }
  .cp__q::-webkit-details-marker { display: none; }
  .cp__q:hover { background: var(--sl-color-gray-7, #f8f7f4); }

  .cp__badge {
    flex-shrink: 0;
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 9px;
    border-radius: 6px;
    background: color-mix(in srgb, var(--sl-color-accent, #0d9488) 14%, transparent);
    color: var(--sl-color-accent, #0d9488);
  }
  .cp__qtext {
    flex: 1;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--sl-color-text, #1a1a2e);
  }
  .cp__chevron {
    flex-shrink: 0;
    color: var(--sl-color-gray-3, #9898ab);
    transition: transform 0.2s;
  }
  .cp[open] .cp__chevron { transform: rotate(90deg); }

  .cp__answer {
    padding: 4px 16px 16px;
    margin-left: 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--sl-color-gray-1, #44445a);
    border-top: 1px solid var(--sl-color-gray-6, #e8e6e1);
    padding-top: 14px;
    animation: cp-reveal 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes cp-reveal {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .cp__answer :global(p:first-child) { margin-top: 0; }
  .cp__answer :global(p:last-child) { margin-bottom: 0; }
  .cp__answer :global(code) {
    font-size: 0.86em;
    background: var(--sl-color-accent-low, #f0fdfa);
    color: var(--sl-color-accent, #0d9488);
    padding: 1px 5px;
    border-radius: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .cp__chevron, .cp__answer { transition: none; animation: none; }
  }
</style>