---
/**
 * Barre de progression + outline scroll-spy façon HackMD.
 *
 * Pourquoi cette version diffère de la naïve :
 *  - Les styles sont GLOBAUX (is:global) car le CSS scopé d'Astro
 *    perd contre les styles globaux de Starlight, et parce que les
 *    éléments sont déplacés hors du composant (voir ci-dessous).
 *  - Les éléments fixes (barre, outline) sont montés directement sur
 *    <body> par le script. Sinon un ancêtre de Starlight avec
 *    `transform`/`contain` capture le `position: fixed` et casse le
 *    positionnement par rapport au viewport.
 *  - z-index élevé pour passer au-dessus du chrome de Starlight.
 *
 * Usage : importer et poser <ReadingProgress /> une fois dans la page
 * (ou dans un override de layout). L'emplacement dans l'arbre n'importe
 * pas — le script remonte les éléments sur body.
 */
---

<script>
  function initReadingProgress() {
    // Éviter les doublons (navigation, re-exécution)
    if (document.getElementById("rp-bar")) {
      document.getElementById("rp-bar")?.remove();
      document.getElementById("rp-outline")?.remove();
    }

    // 1. Trouver la zone de contenu de l'article
    const article =
      document.querySelector(".sl-markdown-content") ||
      document.querySelector("main .sl-markdown-content") ||
      document.querySelector("article") ||
      document.querySelector("main");
    if (!article) return;

    const headings = Array.from(article.querySelectorAll("h2, h3"));

    // 2. Barre de progression — montée sur body
    const bar = document.createElement("div");
    bar.id = "rp-bar";
    const fill = document.createElement("div");
    fill.id = "rp-bar-fill";
    bar.appendChild(fill);
    document.body.appendChild(bar);

    // 3. Outline — monté sur body
    let dots = [];
    let byId = {};
    if (headings.length > 0) {
      const outline = document.createElement("nav");
      outline.id = "rp-outline";
      outline.setAttribute("aria-label", "Progression dans l'article");

      headings.forEach((h, i) => {
        if (!h.id) h.id = "rp-h-" + i;
        const dot = document.createElement("a");
        dot.className = "rp-dot rp-dot--" + h.tagName.toLowerCase();
        dot.href = "#" + h.id;
        const label = document.createElement("span");
        label.className = "rp-dot-label";
        label.textContent = h.textContent || "";
        dot.appendChild(label);
        dot.addEventListener("click", (e) => {
          e.preventDefault();
          h.scrollIntoView({ behavior: "smooth", block: "start" });
        });
        outline.appendChild(dot);
        dots.push(dot);
        byId[h.id] = dot;
      });
      document.body.appendChild(outline);

      // Scroll-spy
      const spy = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              dots.forEach((d) => d.classList.remove("rp-dot--active"));
              const active = byId[entry.target.id];
              if (active) active.classList.add("rp-dot--active");
            }
          });
        },
        { rootMargin: "-10% 0px -80% 0px", threshold: 0 }
      );
      headings.forEach((h) => spy.observe(h));
    }

    // 4. Barre de progression au scroll
    function updateBar() {
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const docHeight =
        document.documentElement.scrollHeight - window.innerHeight;
      const pct = docHeight > 0 ? Math.min(100, (scrollTop / docHeight) * 100) : 0;
      fill.style.width = pct + "%";
    }
    window.addEventListener("scroll", updateBar, { passive: true });
    window.addEventListener("resize", updateBar, { passive: true });
    updateBar();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initReadingProgress);
  } else {
    initReadingProgress();
  }
  // Astro View Transitions
  document.addEventListener("astro:page-load", initReadingProgress);
</script>

<style is:global>
  /* Barre de progression — montée sur body, fixed par rapport au viewport */
  #rp-bar {
    position: fixed !important;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 1000;
    background: transparent;
    pointer-events: none;
  }
  #rp-bar-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(
      90deg,
      var(--sl-color-accent, #0d9488),
      color-mix(in srgb, var(--sl-color-accent, #0d9488) 55%, #22c55e)
    );
    transition: width 0.1s linear;
    border-radius: 0 2px 2px 0;
  }

  /* Outline flottant */
  #rp-outline {
    position: fixed !important;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 999;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 8px 4px;
    margin: 0;
  }
  #rp-outline .rp-dot {
    position: relative;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    margin-bottom: 12px;
    background: var(--sl-color-gray-4, #c2c0ba);
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
    display: block;
    text-decoration: none;
  }
  #rp-outline .rp-dot--h3 {
    width: 6px;
    height: 6px;
    margin-left: 1.5px;
    opacity: 0.65;
  }
  #rp-outline .rp-dot:hover {
    background: var(--sl-color-accent, #0d9488);
    transform: scale(1.3);
  }
  #rp-outline .rp-dot--active {
    background: var(--sl-color-accent, #0d9488);
    transform: scale(1.4);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--sl-color-accent, #0d9488) 18%, transparent);
  }
  #rp-outline .rp-dot--active.rp-dot--h3 { transform: scale(1.5); }

  #rp-outline .rp-dot-label {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%) translateX(-6px);
    white-space: nowrap;
    font-size: 0.72rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 7px;
    color: var(--sl-color-text, #1a1a2e);
    opacity: 0.6;
    pointer-events: none;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    max-width: 240px;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  #rp-outline .rp-dot:hover .rp-dot-label,
  #rp-outline .rp-dot--active .rp-dot-label {
    background: var(--sl-color-bg, #fff);
    opacity: 1;
    border: 1px solid var(--sl-color-gray-5, #e2e0db);
    transform: translateY(-50%) translateX(0);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.12);
  }

  /* Sous 1100px : pas de place pour l'outline. La barre reste. */
  @media (max-width: 1100px) {
    #rp-outline { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    #rp-bar-fill,
    #rp-outline .rp-dot,
    #rp-outline .rp-dot-label { transition: none; }
  }
</style>