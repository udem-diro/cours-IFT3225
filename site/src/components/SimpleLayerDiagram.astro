---
/**
 * Diagramme générique de couches reliées par des connecteurs étiquetés. 
 * Horizontal sur grand écran, vertical sous 680px.
 *
 * Props :
 *   layers      : [{ title, lines?, accent?, focus?: { label, note? } }]
 *   connectors? : [{ label, accent? }]  (un de moins que layers)
 *   caption?    : légende sous le diagramme
 *   ariaLabel?  : description accessible du diagramme
 *
 * La grille est générée à partir du nombre de couches, donc le composant
 * fonctionne pour deux couches comme pour plusieurs.
 */

import Icon from "./Icon.astro"

interface Layer {
  icon?: string;         // URL / chemin vers un SVG externe
  iconSize?: number;     // px, défaut 48
  iconColor?: string;     

  title: string;
  lines?: string[];
  accent?: boolean;
  focus?: { label: string; note?: string };
}

interface Connector {
  label: string;
  accent?: boolean;
}

interface Props {
  layers: Layer[];
  connectors?: Connector[];
  caption?: string;
  ariaLabel?: string;
}

const { layers, connectors = [], caption, ariaLabel } = Astro.props;

const cardCols = "minmax(150px, 220px)";
const connCols = "minmax(42px, 56px)";
const parts: string[] = [];
layers.forEach((_, i) => {
  parts.push(cardCols);
  if (i < layers.length - 1) parts.push(connCols);
});
const cols = parts.join(" ");
const rows = layers.map(() => "auto").join(" 62px ");
const diagramStyle = `--cols: ${cols}; --rows: ${rows};`;
const defIconSize = 24;

const iconWrapperSize = (iconSize:number=defIconSize) => 12 + Number(iconSize);
---

<figure class="layer-diagram">
  <div class="layer-diagram__grid" role="img" aria-label={ariaLabel} style={diagramStyle}>
    {layers.map((layer, i) => (
      <Fragment>
        <section class:list={["layer-card", { "layer-card--accent": layer.accent }]}>
          <header class="layer-card-header">
            {(layer.icon && layer.icon !== "") && (
              <div style={{width: `${iconWrapperSize(layer.iconSize)}px`, height: `${iconWrapperSize(layer.iconSize)}px`}} class="layer-card__icon">
                <Icon name={layer.icon} size={layer.iconSize ?? defIconSize} color={layer.iconColor} />
              </div>
              )}

            <h4>{layer.title}</h4>
          </header>


          {layer.lines && layer.lines.length > 0 && (
            <div class="layer-card__content">
              {layer.lines.map((line) => <p>{line}</p>)}
            </div>
          )}

          {layer.focus && (
            <div class="layer-card__focus">
              <strong>{layer.focus.label}</strong>
              {layer.focus.note && <small>{layer.focus.note}</small>}
            </div>
          )}
        </section>

        {i < layers.length - 1 && connectors[i] && (
          <div class:list={["layer-connector", { "layer-connector--accent": connectors[i].accent }]}>
            <span class="layer-connector__label">{connectors[i].label}</span>
            <span class="layer-connector__line" aria-hidden="true"></span>
          </div>
        )}
      </Fragment>
    ))}
  </div>

  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .layer-diagram {
    --accent: #0d9488;
    --border-color: currentColor;

    width: min(100%, 720px);
    margin: 1.75rem auto;
    color: inherit;
    font-family: inherit;
  }

  .layer-diagram__grid {
    display: grid;
    grid-template-columns: var(--cols);
    align-items: center;
    justify-content: center;
  }

  .layer-card {
    box-sizing: border-box;
    min-height: 160px;
    height: 100%;
    padding: 19px 16px 14px;
    border: 1.5px solid var(--border-color);
    border-radius: 12px;
    text-align: center;
  }

  .layer-card--accent {
    border-width: 2px;
    border-color: var(--accent);
  }

  .layer-card-header {
    display: flex; flex-direction: column;
    align-items: center;
  }

  .layer-card__icon {
    display: flex; align-items: center; justify-content: center;
    background-color: #f0f0f0;
    padding: 8px;
    border-radius: 50%;
    box-shadow: 0 1px 2px -0.5px #c0c0c0;
  }

  .layer-card__title {
    margin: 0; margin-top: 6px;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
  }

  .layer-card__content {
    margin-top: 26px;
    font-size: 12px;
    line-height: 1.35;
    opacity: 0.7;
  }

  .layer-card__content p {
    margin: 0 0 8px;
  }

  .layer-card__content p:last-child {
    margin-bottom: 0;
  }

  .layer-card__focus {
    display: grid;
    gap: 11px;
    margin-top: 17px;
    color: var(--accent);
  }

  .layer-card__focus strong {
    font-size: 13px;
    font-weight: 600;
  }

  .layer-card__focus small {
    font-size: 10.5px;
  }

  /* Connecteurs */

  .layer-connector {
    position: relative;
    display: grid;
    align-items: center;
    min-width: 0;
    color: currentColor;
    opacity: 0.7;
  }

  .layer-connector--accent {
    color: var(--accent);
    opacity: 1;
  }

  .layer-connector__label {
    position: absolute;
    bottom: 10px;
    left: 50%;
    z-index: 1;
    padding: 0 3px;
    background: Canvas;
    background: color-mix(in srgb, Canvas 96%, transparent);
    font-size: 11px;
    line-height: 1;
    white-space: nowrap;
    transform: translateX(-50%);
  }

  .layer-connector__line {
    position: relative;
    display: block;
    width: 100%;
    height: 2px;
    background: currentColor;
  }

  /* Pointes des flèches bidirectionnelles */

  .layer-connector__line::before,
  .layer-connector__line::after {
    position: absolute;
    top: 50%;
    width: 0;
    height: 0;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    content: "";
    transform: translateY(-50%);
  }

  .layer-connector__line::before {
    left: 0;
    border-right: 8px solid currentColor;
  }

  .layer-connector__line::after {
    right: 0;
    border-left: 8px solid currentColor;
  }

  .layer-diagram figcaption {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    line-height: 1.45;
    text-align: center;
    opacity: 0.7;
  }

  /* Version verticale */

  @media (max-width: 680px) {
    .layer-diagram__grid {
      grid-template-columns: minmax(0, 360px);
      grid-template-rows: var(--rows);
      padding-inline: 0.75rem;
    }

    .layer-card {
      width: 100%;
      min-height: 150px;
    }

    .layer-connector {
      width: 100%;
      height: 62px;
      justify-items: center;
    }

    .layer-connector__line {
      width: 1.5px;
      height: 100%;
    }

    .layer-connector__line::before,
    .layer-connector__line::after {
      left: 50%;
      border-right: 5px solid transparent;
      border-left: 5px solid transparent;
      transform: translateX(-50%);
    }

    .layer-connector__line::before {
      top: 0;
      border-top: 0;
      border-bottom: 8px solid currentColor;
    }

    .layer-connector__line::after {
      top: auto;
      right: auto;
      bottom: 0;
      border-top: 8px solid currentColor;
      border-bottom: 0;
    }

    .layer-connector__label {
      bottom: auto;
      left: calc(50% + 12px);
      top: 50%;
      transform: translateY(-50%);
    }
  }
</style>