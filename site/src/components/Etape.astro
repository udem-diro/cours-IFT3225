---
/**
 * Etape.astro
 *
 * Enveloppe une section de la page et la rend observable par le panneau
 * flottant (PanneauFichiers). L'attribut data-etape doit correspondre à
 * l'identifiant d'une étape déclarée dans le module de données.
 *
 * Usage (dans MDX, en laissant des lignes vides autour du contenu) :
 *   <Etape id="p1">
 *
 *   ## 1. Le composant connait la source
 *
 *   Du texte en Markdown.
 *
 *   </Etape>
 */

interface Props {
  id: string;
}

const { id } = Astro.props;
---

<section id={id} data-etape={id} class="etape">
  <slot />
</section>

<style>
  .etape {
    scroll-margin-top: 80px;
  }
</style>