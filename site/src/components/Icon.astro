---
/**
 * Composant de résolution d'icônes Lucide.
 * Centralise le mapping nom → composant pour tous les composants du site.
 *
 * Usage :
 *   import Icon from './Icon.astro';
 *   <Icon name="server" size={18} />
 */

import {
  BookOpen,
  Braces,
  Calendar,
  ChartLine,
  ClipboardList,
  Cloud,
  Code,
  Database,
  FileText,
  Flag,
  FlaskConical,
  Globe,
  GraduationCap,
  Laptop,
  ListTodo,
  Lightbulb,
  Lock,
  Map,
  Menu,
  Moon,
  Package,
  Pen,
  Presentation,
  Puzzle,
  Radio,
  RefreshCw,
  Rocket,
  Scale,
  Server,
  Settings,
  SlidersHorizontal,
  Smartphone,
  Sun,
  Target,
  Wrench,
  X,
} from "@lucide/astro";

const icons: Record<string, any> = {
  'book-open':    BookOpen,
  'braces':       Braces,
  'calendar':     Calendar,
  'clipboard':    ClipboardList,
  'cloud':        Cloud,
  'code':         Code,
  'database':     Database,
  'file-text':    FileText,
  'flask':        FlaskConical,
  'flag':         Flag,
  'globe':        Globe,
  'graduation':   GraduationCap,
  'laptop':       Laptop,
  'chart-line':   ChartLine,
  'lock':         Lock,
  'list-todo':    ListTodo,
  'lightbulb':    Lightbulb,
  'map':          Map,
  'menu':         Menu,
  'moon':         Moon,
  'package':      Package,
  'pen':          Pen,
  'presentation': Presentation,
  'puzzle':       Puzzle,
  'radio':        Radio,
  'refresh':      RefreshCw,
  'rocket':       Rocket,
  'scale':        Scale,
  'server':       Server,
  'settings':     Settings,
  'sliders-horizontal' : SlidersHorizontal,
  'smartphone':   Smartphone,
  'sun':          Sun,
  'target':       Target,
  'wrench':       Wrench,
  'x':            X,
};

interface Props {
  name: string;
  color?: string;
  size?: number;
  class?: string;
}

const { name, size = 18, color = "#555", class: className } = Astro.props;
const IconComponent = icons[name];
---

{IconComponent ? (
  <IconComponent size={size} color={color} class:list={["icon", className]} />
) : (
  <i class:list={["icon", className]}>{name}</i>
)}

<style>
  .icon {
    display: inline-block;
    font-style: normal;
    vertical-align: middle;
  }
</style>
