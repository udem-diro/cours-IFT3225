---
/**
 * Consideration.astro — carte de considérations pour une technologie.
 *
 * Partage la source de données (persistence-config.js) et l'identité visuelle
 * (catégorie + icône + couleur par question) avec l'aside du composant
 * PersistenceExplorer, pour que la version longue de la page et l'explorateur
 * interactif parlent le même langage.
 *
 * Usage : <Consideration tech="cookie" />
 */
import { defaultConfig } from "./react/persistence-config.js";
import Icon from "./Icon.astro"

const { tech, config } = Astro.props;
const C = config ?? defaultConfig;
const cons = C.considerations[tech];
const questions = C.questions;

const ICONS = {
  need: "list-todo",
  store: "database",
  control: "sliders-horizontal",
  limit: "flag",
  when: "target",
  code: "code",
};
---

{cons && (
  <div class="c-card">
    <div class="c-eyebrow">Considérations</div>
    <div class="c-nom">{cons.nom}</div>
    <div class="c-grid">
      {questions.map((q) => (
        <div class={"c-qa c-qa--" + q.key}>
          <div class="c-qhead">
            <span class="c-qicon">
                <Icon name={ICONS[q.icon]} />
                {/* <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[q.icon]} /> */}
            </span>
            <span class="c-qtag">{q.tag}</span>
          </div>
          <div class="c-q">{q.label}</div>
          <div class="c-a">{cons[q.key]}</div>
        </div>
      ))}
    </div>
    {cons.exploiter && (
      <div class="c-exp">
        <div class="c-qhead">
          <span class="c-qicon c-qicon--code"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS.code} /></span>
          <span class="c-qtag">Comment l'exploiter</span>
        </div>
        <code class="c-expcode">{cons.exploiter}</code>
      </div>
    )}
  </div>
)}

<style>
  .c-card {
    border: 1px solid #e2e0db; border-radius: 14px; padding: 16px 18px;
    background: #f8f7f4; margin: 1.5rem 0; font-variant-ligatures: none;
  }
  .c-eyebrow { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #6b6b80; }
  .c-nom { font-family: 'Fraunces', Georgia, serif; font-weight: 700; font-size: 1.1rem; color: #0d9488; margin: 2px 0 14px; }
  .c-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 14px; }
  .c-qa { padding-left: 11px; border-left: 2px solid #e2e0db; }
  .c-qhead { display: flex; align-items: center; gap: 7px; margin-bottom: 5px; }
  .c-qicon { display: inline-flex; align-items: center; justify-content: center; width: 24px; height: 24px; border-radius: 7px; flex-shrink: 0; color: #475569; background: #eef2f0; }
  .c-qicon svg { width: 15px; height: 15px; }
  .c-qtag { font-size: 0.64rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #6b6b80; }
  .c-q { font-size: 0.84rem; font-weight: 700; color: #1a1a2e; margin-bottom: 3px; line-height: 1.3; }
  .c-a { font-size: 0.84rem; color: #555; line-height: 1.5; }

  .c-qa--besoin { border-left-color: #0d9488; }
  .c-qa--besoin .c-qicon { color: #0d9488; background: color-mix(in srgb, #0d9488 12%, transparent); }
  .c-qa--stocker { border-left-color: #3b82f6; }
  .c-qa--stocker .c-qicon { color: #3b82f6; background: color-mix(in srgb, #3b82f6 12%, transparent); }
  .c-qa--controle { border-left-color: #8b5cf6; }
  .c-qa--controle .c-qicon { color: #8b5cf6; background: color-mix(in srgb, #8b5cf6 12%, transparent); }
  .c-qa--limites { border-left-color: #d97706; }
  .c-qa--limites .c-qicon { color: #d97706; background: color-mix(in srgb, #d97706 14%, transparent); }
  .c-qa--quand { border-left-color: #16a34a; }
  .c-qa--quand .c-qicon { color: #16a34a; background: color-mix(in srgb, #16a34a 12%, transparent); }

  .c-exp { margin-top: 16px; padding-top: 13px; border-top: 1px solid #e2e0db; }
  .c-qicon--code { color: #1e293b; background: #e2e8f0; }
  .c-expcode {
    display: block; margin-top: 6px; font-family: 'JetBrains Mono', monospace;
    font-size: 0.76rem; line-height: 1.55; color: #1e293b; background: #eef2f0;
    border: 1px solid #e2e0db; border-radius: 8px; padding: 9px 11px;
    white-space: pre-wrap; word-break: break-word;
  }

  :global([data-theme="dark"]) .c-card { background: #1e1e2e; border-color: #2c2c40; }
  :global([data-theme="dark"]) .c-q { color: #e7e7ef; }
  :global([data-theme="dark"]) .c-a { color: #a9a9bc; }
  :global([data-theme="dark"]) .c-qa { border-left-color: #2c2c40; }
  :global([data-theme="dark"]) .c-qicon { background: rgba(255,255,255,0.08); }
  :global([data-theme="dark"]) .c-exp { border-top-color: #2c2c40; }
  :global([data-theme="dark"]) .c-expcode { background: #15151f; color: #cdd6f4; border-color: #2c2c40; }
  :global([data-theme="dark"]) .c-qa--besoin .c-qicon { background: color-mix(in srgb, #0d9488 22%, transparent); }
  :global([data-theme="dark"]) .c-qa--stocker .c-qicon { background: color-mix(in srgb, #3b82f6 22%, transparent); }
  :global([data-theme="dark"]) .c-qa--controle .c-qicon { background: color-mix(in srgb, #8b5cf6 22%, transparent); }
  :global([data-theme="dark"]) .c-qa--limites .c-qicon { background: color-mix(in srgb, #d97706 24%, transparent); }
  :global([data-theme="dark"]) .c-qa--quand .c-qicon { background: color-mix(in srgb, #16a34a 22%, transparent); }
</style>