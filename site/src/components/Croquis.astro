---
// Croquis : petit schéma illustrant un type de représentation (section « Choisir une
// représentation »). Rendu en SVG inline, volontairement schématique.
const { type, legende } = Astro.props;
const teal = "#0d9488";
const ambre = "#d97706";
const gris = "#9aa1ad";
---
<figure class="croquis">
  {type === "barres" && (
    <svg viewBox="0 0 260 130" role="img" aria-label="Diagramme à barres">
      <line x1="22" y1="106" x2="244" y2="106" stroke="#d8d6d0" />
      <rect x="34" y="60" width="30" height="46" fill={teal} rx="2" />
      <rect x="76" y="30" width="30" height="76" fill={teal} rx="2" />
      <rect x="118" y="70" width="30" height="36" fill={teal} rx="2" />
      <rect x="160" y="16" width="30" height="90" fill={teal} rx="2" />
      <rect x="202" y="46" width="30" height="60" fill={teal} rx="2" />
    </svg>
  )}
  {type === "distribution" && (
    <svg viewBox="0 0 260 130" role="img" aria-label="Histogramme">
      <line x1="22" y1="106" x2="244" y2="106" stroke="#d8d6d0" />
      {[18, 42, 74, 96, 68, 36, 16].map((h, i) => (
        <rect x={40 + i * 26} y={106 - h} width="25" height={h} fill={teal} opacity="0.85" />
      ))}
    </svg>
  )}
  {type === "nuage" && (
    <svg viewBox="0 0 260 130" role="img" aria-label="Nuage de points">
      <line x1="30" y1="106" x2="244" y2="106" stroke="#d8d6d0" />
      <line x1="30" y1="106" x2="30" y2="16" stroke="#d8d6d0" />
      <line x1="40" y1="98" x2="230" y2="34" stroke={ambre} stroke-width="1.5" stroke-dasharray="4 3" opacity="0.6" />
      {[[52,92],[70,84],[86,88],[104,70],[120,74],[136,58],[150,64],[168,48],[182,52],[198,40],[214,44],[96,60],[142,80],[190,66]].map(([x, y]) => (
        <circle cx={x} cy={y} r="4" fill={teal} opacity="0.85" />
      ))}
    </svg>
  )}
  {type === "composition" && (
    <svg viewBox="0 0 260 130" role="img" aria-label="Barres empilées">
      <line x1="22" y1="106" x2="244" y2="106" stroke="#d8d6d0" />
      {[[46,30,26],[52,24,28],[38,40,20],[44,20,36]].map(([a, b, c], i) => {
        const x = 42 + i * 52;
        return (
          <g>
            <rect x={x} y={106 - a} width="38" height={a} fill={teal} />
            <rect x={x} y={106 - a - b} width="38" height={b} fill={ambre} opacity="0.9" />
            <rect x={x} y={106 - a - b - c} width="38" height={c} fill={gris} opacity="0.7" />
          </g>
        );
      })}
    </svg>
  )}
  {type === "temporel" && (
    <svg viewBox="0 0 260 130" role="img" aria-label="Graphique linéaire">
      <line x1="26" y1="106" x2="244" y2="106" stroke="#d8d6d0" />
      <polyline points="30,86 60,70 90,78 120,50 150,58 180,34 210,44 236,24" fill="none" stroke={teal} stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" />
      {[[30,86],[60,70],[90,78],[120,50],[150,58],[180,34],[210,44],[236,24]].map(([x, y]) => (
        <circle cx={x} cy={y} r="3" fill={teal} />
      ))}
    </svg>
  )}
  {legende && <figcaption>{legende}</figcaption>}
</figure>

<style>
  .croquis { margin: 12px 0 4px; }
  .croquis svg { width: 100%; max-width: 300px; height: auto; background: #f7f6f3; border: 1px solid #ebe9e4; border-radius: 10px; padding: 8px; }
  .croquis figcaption { margin-top: 5px; font-size: 0.78rem; color: #9aa1ad; }
</style>