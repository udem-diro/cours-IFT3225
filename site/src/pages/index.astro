---

<BaseLayout title="IFT3225 — Technologies de l'internet">
  <div class="home">
    <header class="home__hero">
      <span class="home__eyebrow">Université de Montréal · Été 2026</span>
      <h1 class="home__title">Technologies de l'internet</h1>
      <p class="home__lede">
        Comprendre comment les systèmes communiquent : des protocoles aux API,
        du serveur à la base de données, du concept au code.
      </p>
      <p class="home__note">Chaque carte mène à la page du sujet ; le bouton « Réviser » déroule ses fiches.</p>
    </header>

    <section class="home__grid">
      {sujets.map((s) => (
        <article class="subject">
          <a class="subject__hit" href={s.liens[0].href}>
            <h2 class="subject__titre">{s.titre}</h2>
            <p class="subject__resume">{s.resume}</p>
            <div class="subject__themes">
              {s.themes.map((t) => <span class="chip">{t}</span>)}
            </div>
          </a>
          <div class="subject__foot">
            <ul class="subject__liens">
              {s.liens.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
            </ul>
            <button class="subject__revise" type="button" data-titre={s.titre} data-fiches={JSON.stringify(s.fiches)}>Réviser →</button>
          </div>
        </article>
      ))}
    </section>
  </div>

  <div class="amodal" id="amodal" hidden>
    <div class="amodal__backdrop" data-close></div>
    <div class="amodal__panel" role="dialog" aria-modal="true" aria-label="Fiches de révision du sujet">
      <header class="amodal__head">
        <h2 class="amodal__titre"></h2>
        <div class="amodal__actions">
          <span class="amodal__counter"></span>
          <button class="amodal__close" type="button" data-close aria-label="Fermer">×</button>
        </div>
      </header>
      <div class="deckwrap">
        <button class="deck__nav deck__nav--prev" type="button" aria-label="Fiche précédente">‹</button>
        <div class="deck"></div>
        <button class="deck__nav deck__nav--next" type="button" aria-label="Fiche suivante">›</button>
      </div>
      <div class="deck__dots"></div>
    </div>
  </div>

  <style>
    .home { max-width: 940px; margin: 0 auto; }
    .home__hero { padding: 2rem 0 2.4rem; border-bottom: 1px solid var(--c-border); margin-bottom: 2.6rem; }
    .home__eyebrow {
      font-family: var(--mono); font-size: 0.78rem; font-weight: 600;
      letter-spacing: 0.04em; color: var(--c-accent); text-transform: uppercase;
    }
    .home__title {
      font-family: var(--serif); font-size: clamp(2.4rem, 6vw, 3.6rem); font-weight: 700;
      letter-spacing: -0.02em; line-height: 1.1; margin: 0.6rem 0 1rem; color: var(--c-text);
    }
    .home__lede { font-size: 1.25rem; line-height: 1.6; color: var(--c-muted); max-width: 620px; margin: 0; }
    .home__note { font-size: 0.85rem; color: var(--c-dim); margin: 1rem 0 0; font-style: italic; }

    .home__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 1.4rem; }

    .subject {
      position: relative; display: flex; flex-direction: column; min-height: 230px;
      padding: 1.5rem; background: var(--c-surface);
      border: 1px solid var(--c-border); border-radius: var(--radius);
      transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .subject:hover { border-color: var(--c-accent); transform: translateY(-2px); box-shadow: 0 12px 30px rgba(0,0,0,0.06); }
    .subject__hit { display: flex; flex-direction: column; flex: 1 1 auto; text-decoration: none; color: inherit; }
    .subject__hit::after {
      content: "→"; position: absolute; top: 1.5rem; right: 1.5rem; font-family: var(--mono);
      font-size: 0.95rem; color: var(--c-accent); opacity: 0; transform: translateX(-4px);
      transition: opacity 0.2s, transform 0.2s;
    }
    .subject:hover .subject__hit::after { opacity: 1; transform: translateX(0); }
    .subject__titre { font-family: var(--serif); font-size: 1.22rem; font-weight: 600; margin: 0 0 0.5rem; color: var(--c-text); transition: color 0.15s; }
    .subject__hit:hover .subject__titre { color: var(--c-accent); }
    .subject__resume { font-size: 0.92rem; line-height: 1.55; color: var(--c-muted); margin: 0 0 0.9rem; }
    .subject__themes { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1rem; }
    .chip { font-size: 0.68rem; font-weight: 600; padding: 2px 9px; border-radius: 100px; background: var(--c-accent-b); color: var(--c-accent); }
    .subject__foot { margin-top: auto; padding-top: 0.9rem; border-top: 1px solid var(--c-border); display: flex; flex-direction: column; gap: 0.7rem; }
    .subject__liens { list-style: none; margin: 0; padding: 0; }
    .subject__liens li { margin: 0.3rem 0; }
    .subject__liens a { color: var(--c-mid); text-decoration: none; font-size: 0.9rem; transition: color 0.15s; }
    .subject__liens a:hover { color: var(--c-accent); text-decoration: underline; }
    .subject__revise {
      align-self: flex-start; background: none; border: none; padding: 0; cursor: pointer;
      font-family: var(--mono); font-size: 0.72rem; font-weight: 600; color: var(--c-accent);
    }
    .subject__revise:hover { text-decoration: underline; }

    /* Superposition + carrousel de fiches */
    .amodal { position: fixed; inset: 0; z-index: 100; display: flex; align-items: center; justify-content: center; padding: 2rem; }
    .amodal[hidden] { display: none; }
    .amodal__backdrop { position: absolute; inset: 0; background: rgba(18, 18, 28, 0.55); backdrop-filter: blur(3px); }
    .amodal__panel { position: relative; width: 100%; max-width: 600px; }
    .amodal__head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
    .amodal__titre { font-family: var(--serif); font-size: clamp(1.3rem, 3vw, 1.6rem); font-weight: 700; color: #fff; margin: 0; }
    .amodal__actions { display: flex; align-items: center; gap: 0.9rem; flex-shrink: 0; }
    .amodal__counter { font-family: var(--mono); font-size: 0.8rem; color: rgba(255,255,255,0.8); }
    .amodal__close {
      width: 36px; height: 36px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.35);
      background: rgba(255,255,255,0.08); color: #fff; font-size: 1.4rem; line-height: 1; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
    }
    .amodal__close:hover { background: rgba(255,255,255,0.18); }

    .deckwrap { position: relative; }
    .deck {
      display: flex; gap: 1rem; overflow-x: auto; scroll-snap-type: x mandatory;
      scroll-behavior: smooth; scrollbar-width: none; padding-bottom: 2px;
    }
    .deck::-webkit-scrollbar { display: none; }
    :global(.flash) {
      flex: 0 0 calc(100% - 40px); scroll-snap-align: center; box-sizing: border-box;
      min-height: 340px; max-height: 64vh; overflow: auto;
      padding: 1.7rem 1.9rem; background: var(--c-surface);
      border: 1px solid var(--c-border); border-top: 3px solid var(--c-accent);
      border-radius: 16px; box-shadow: 0 24px 60px rgba(0,0,0,0.32);
    }
    :global(.flash__n) { font-family: var(--mono); font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--c-dim); }
    :global(.flash__t) { font-family: var(--serif); font-size: 1.4rem; font-weight: 700; color: var(--c-accent); margin: 0.3rem 0 0.9rem; }
    :global(.flash__p) { font-size: 0.98rem; line-height: 1.66; color: var(--c-text); margin: 0 0 0.85rem; }
    :global(.flash__p:last-child) { margin-bottom: 0; }

    .deck__nav {
      position: absolute; top: 50%; transform: translateY(-50%); z-index: 5;
      width: 42px; height: 42px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.3);
      background: rgba(20,20,30,0.6); color: #fff; font-size: 1.5rem; line-height: 1; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
    }
    .deck__nav--prev { left: -16px; } .deck__nav--next { right: -16px; }
    .deck__nav:hover:not(:disabled) { background: var(--c-accent); border-color: var(--c-accent); }
    .deck__nav:disabled { opacity: 0.25; cursor: default; }

    .deck__dots { display: flex; justify-content: center; gap: 0.5rem; margin-top: 1.1rem; }
    :global(.deck__dot) { width: 8px; height: 8px; border-radius: 50%; border: none; padding: 0; cursor: pointer; background: rgba(255,255,255,0.35); transition: transform 0.15s, background 0.15s; }
    :global(.deck__dot--on) { background: #fff; transform: scale(1.3); }

    @media (max-width: 760px) {
      .amodal { padding: 1rem; align-items: flex-start; overflow-y: auto; }
      :global(.flash) { flex-basis: calc(100% - 24px); min-height: auto; max-height: none; overflow: visible; padding: 1.4rem; }
      .deck__nav--prev { left: -4px; } .deck__nav--next { right: -4px; }
    }
  </style>

  <script>
    const modal = document.getElementById("amodal");
    const titreEl = modal.querySelector(".amodal__titre");
    const counter = modal.querySelector(".amodal__counter");
    const deck = modal.querySelector(".deck");
    const dots = modal.querySelector(".deck__dots");
    const prevBtn = modal.querySelector(".deck__nav--prev");
    const nextBtn = modal.querySelector(".deck__nav--next");

    function build(fiches) {
      deck.innerHTML = "";
      dots.innerHTML = "";
      fiches.forEach((f, i) => {
        const card = document.createElement("article");
        card.className = "flash";
        const eb = document.createElement("span");
        eb.className = "flash__n";
        eb.textContent = "Fiche " + (i + 1) + " / " + fiches.length;
        const h = document.createElement("h3");
        h.className = "flash__t";
        h.textContent = f.t;
        card.append(eb, h);
        (f.p ?? []).forEach((par) => {
          const p = document.createElement("p");
          p.className = "flash__p";
          p.textContent = par;
          card.append(p);
        });
        deck.append(card);

        const dot = document.createElement("button");
        dot.className = "deck__dot";
        dot.type = "button";
        dot.setAttribute("aria-label", "Fiche " + (i + 1));
        dot.addEventListener("click", () => goTo(i));
        dots.append(dot);
      });
    }

    function currentIndex() {
      const cards = Array.from(deck.children);
      if (!cards.length) return 0;
      const center = deck.scrollLeft + deck.clientWidth / 2;
      let best = 0, bestDist = Infinity;
      cards.forEach((c, k) => {
        const cc = c.offsetLeft + c.offsetWidth / 2;
        const d = Math.abs(cc - center);
        if (d < bestDist) { bestDist = d; best = k; }
      });
      return best;
    }
    function goTo(i) {
      const card = deck.children[i];
      if (!card) return;
      const left = card.offsetLeft - (deck.clientWidth - card.offsetWidth) / 2;
      deck.scrollTo({ left, behavior: "smooth" });
    }
    function update() {
      const n = deck.children.length;
      const i = currentIndex();
      counter.textContent = n ? (i + 1) + " / " + n : "";
      Array.from(dots.children).forEach((d, k) => d.classList.toggle("deck__dot--on", k === i));
      prevBtn.disabled = i <= 0;
      nextBtn.disabled = i >= n - 1;
    }

    function openModal(titre, fiches) {
      titreEl.textContent = titre;
      build(Array.isArray(fiches) ? fiches : []);
      modal.hidden = false;
      document.body.style.overflow = "hidden";
      deck.scrollLeft = 0;
      update();
    }
    function closeModal() {
      modal.hidden = true;
      document.body.style.overflow = "";
    }

    let raf = 0;
    deck.addEventListener("scroll", () => { cancelAnimationFrame(raf); raf = requestAnimationFrame(update); });
    prevBtn.addEventListener("click", () => goTo(currentIndex() - 1));
    nextBtn.addEventListener("click", () => goTo(currentIndex() + 1));

    document.querySelectorAll(".subject__revise").forEach((btn) => {
      btn.addEventListener("click", () => {
        let fiches = [];
        try { fiches = JSON.parse(btn.getAttribute("data-fiches") ?? "[]"); } catch (err) { fiches = []; }
        openModal(btn.getAttribute("data-titre") ?? "", fiches);
      });
    });
    modal.querySelectorAll("[data-close]").forEach((b) => b.addEventListener("click", closeModal));
    document.addEventListener("keydown", (e) => {
      if (modal.hidden) return;
      if (e.key === "Escape") closeModal();
      else if (e.key === "ArrowLeft") goTo(currentIndex() - 1);
      else if (e.key === "ArrowRight") goTo(currentIndex() + 1);
    });
  </script>
</BaseLayout>