---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Lien { label: string; href: string; }
interface Sujet {
  titre: string;
  resume: string;
  themes: string[];
  liens: Lien[];
}

const sujets: Sujet[] = [
  {
    titre: "Fondations : JavaScript et Node",
    resume: "Le socle : modules ES, code asynchrone, et l'écosystème npm pour bâtir et exécuter du JavaScript moderne.",
    themes: ["ES Modules", "fetch / async-await", "npm", "Node.js"],
    liens: [
      { label: "Node.js et npm", href: "/guides/tuto-nodejs" },
      { label: "JavaScript : base de programmation", href: "/guides/tuto-javascript-1" },
      { label: "JavaScript : modules, fetch, async", href: "/guides/tuto-javascript-2" },
    ],
  },
  {
    titre: "Le serveur et les API",
    resume: "Recevoir des requêtes, router, répondre : Express, les middlewares, et la conception d'API lisibles et cohérentes.",
    themes: ["Express", "middleware", "REST", "endpoints"],
    liens: [
      { label: "Concevoir une API", href: "/notes/conception-api" },
      { label: "Prise en main d'Express", href: "/guides/tuto-express" },
      // { label: "Les middlewares dans Express", href: "/notes/middlewares-express" },
    ],
  },
  {
    titre: "Persistance et bases de données",
    resume: "HTTP est sans état : choisir où préserver l'information (client, mémoire serveur, base de données, cache) selon le besoin.",
    themes: ["cookies", "sessions", "base de données", "cache"],
    liens: [
      { label: "Choisir une stratégie de persistance", href: "/notes/persistance" },
      { label: "Prise en main de MongoDB", href: "/guides/tuto-mongo" },
    ],
  },
  {
    titre: "Identité, authentification, autorisation",
    resume: "Reconnaître l'utilisateur et contrôler ses accès : sessions, jetons, rôles, et délégation entre services.",
    themes: ["sessions", "jetons", "rôles", "délégation"],
    liens: [
      { label: "Identité et authentification", href: "/notes/identite" }
    ],
  },
  {
    titre: "Le navigateur et le DOM",
    resume: "Manipuler la page côté client : sélectionner des éléments, les modifier, et réagir aux actions de l'utilisateur.",
    themes: ["DOM", "événements", "sélection", "délégation"],
    liens: [
      { label: "Les bases du DOM", href: "/guides/tuto-dom-1" },
      { label: "Le DOM avancé", href: "/guides/tuto-dom-2" },
    ],
  },
  {
    titre: "Le développement côté client",
    resume: "Garder l'affichage en phase avec un état qui change, composer l'interface, et situer les outils modernes du front-end.",
    themes: ["réactivité", "composants", "React", "Vite"],
    liens: [
      { label: "Concevoir une interface réactive", href: "/notes/interface-reactive" },
      { label: "Construire une TodoList en natif", href: "/guides/tuto-todolist" },
      { label: "Outils du développement web moderne", href: "/notes/outils-frontend" },
    ],
  },
  {
    titre: "React",
    resume: "Construire l'interface par composants : props et état, hooks et cycle de vie, puis routage, contexte partagé et adaptation à l'utilisateur.",
    themes: ["composants", "hooks", "contexte", "i18n"],
    liens: [
      { label: "Prise en main de React", href: "/guides/tuto-react-1" },
      { label: "Hooks et cycle de vie", href: "/guides/tuto-react-3" },
      { label: "React pour des applications complexes", href: "/guides/tuto-react-3" },
    ],
  },
];
---

<BaseLayout title="IFT3225 · Technologies de l'internet">
  <div class="home">
    <header class="home__hero">
      <h1 class="home__title">Technologies de l'internet</h1>
      <p class="home__lede">
        Comprendre comment des systèmes et acteurs communiquent sur internet, grâce à des protocoles qui structurent leurs échanges : 
        de l'objet connecté qui émet de l'information, au serveur qui la reçoit, l'interprète, la conserve et l'expose à des clients 
        qui la mettent en forme pour satisfaire aux besoins des consommateurs finaux. 
        Ce cours en explore les technologies intervenant dans ces échanges, du concept à la mise en œuvre.
      </p>
    </header>

    <section class="home__grid">
      {sujets.map((s) => (
        <article class="subject">
          <a class="subject__hit" href={s.liens[0].href}>
            <h2 class="subject__titre">{s.titre}</h2>
            <p class="subject__resume">{s.resume}</p>
            <div class="subject__themes">
              {s.themes.map((t) => <span class="chip">{t}</span>)}
            </div>
          </a>
          <div class="subject__foot">
            <ul class="subject__liens">
              {s.liens.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
            </ul>
          </div>
        </article>
      ))}
    </section>
  </div>

  <style>
    .home { max-width: 940px; margin: 0 auto; }
    .home__hero { padding: 2rem 0 2.4rem; border-bottom: 1px solid var(--c-border); margin-bottom: 2.6rem; }
    .home__title {
      font-family: var(--serif); font-size: clamp(2.4rem, 6vw, 3.6rem); font-weight: 700;
      letter-spacing: -0.02em; line-height: 1.1; margin: 0.6rem 0 1rem; color: var(--c-text);
    }
    .home__lede { font-size: 1.25rem; line-height: 1.6; color: var(--c-muted); max-width: 720px; margin: 0; }

    .home__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 1.4rem; }

    .subject {
      position: relative; display: flex; flex-direction: column; min-height: 230px;
      padding: 1.5rem; background: var(--c-surface);
      border: 1px solid var(--c-border); border-radius: var(--radius);
      transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .subject:hover { border-color: var(--c-accent); transform: translateY(-2px); box-shadow: 0 12px 30px rgba(0,0,0,0.06); }
    .subject__hit { display: flex; flex-direction: column; flex: 1 1 auto; text-decoration: none; color: inherit; }
    .subject__hit::after {
      content: "→"; position: absolute; top: 1.5rem; right: 1.5rem; font-family: var(--mono);
      font-size: 0.95rem; color: var(--c-accent); opacity: 0; transform: translateX(-4px);
      transition: opacity 0.2s, transform 0.2s;
    }
    .subject:hover .subject__hit::after { opacity: 1; transform: translateX(0); }
    .subject__titre { font-family: var(--serif); font-size: 1.22rem; font-weight: 600; margin: 0 0 0.5rem; color: var(--c-text); transition: color 0.15s; }
    .subject__hit:hover .subject__titre { color: var(--c-accent); }
    .subject__resume { font-size: 0.92rem; line-height: 1.55; color: var(--c-muted); margin: 0 0 0.9rem; }
    .subject__themes { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1rem; }
    .chip { font-size: 0.68rem; font-weight: 600; padding: 2px 9px; border-radius: 100px; background: var(--c-accent-b); color: var(--c-accent); }
    .subject__foot { margin-top: auto; padding-top: 0.9rem; border-top: 1px solid var(--c-border); }
    .subject__liens { list-style: none; margin: 0; padding: 0; }
    .subject__liens li { margin: 0.3rem 0; }
    .subject__liens a { color: var(--c-mid); text-decoration: none; font-size: 0.9rem; transition: color 0.15s; }
    .subject__liens a:hover { color: var(--c-accent); text-decoration: underline; }
  </style>
</BaseLayout>