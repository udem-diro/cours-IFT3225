---
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * Page d'accueil : une carte par sujet (résumé, thèmes clés, pages liées).
 * Le corps de la carte est un lien vers la page principale du sujet. Le bouton
 * « Réviser » ouvre une superposition de FICHES DE RÉVISION en carrousel
 * (flèches, points, glissement). Chaque fiche fait deux à trois paragraphes.
 */
interface Lien { label: string; href: string; }
interface Fiche { t: string; p: string[]; }
interface Sujet {
  titre: string;
  resume: string;
  themes: string[];
  liens: Lien[];
  fiches: Fiche[];
}

const sujets: Sujet[] = [
  {
    titre: "Fondations — JavaScript et Node",
    resume: "Le socle : modules ES, code asynchrone, et l'écosystème npm pour bâtir et exécuter du JavaScript moderne.",
    themes: ["ES Modules", "fetch / async-await", "npm", "Node.js"],
    liens: [
      { label: "Node.js et npm", href: "/guides/tuto-nodejs" },
      { label: "JS — base de programmation", href: "/guides/tuto-javascript-1" },
      { label: "JS — modules, fetch, async", href: "/guides/tuto-javascript-2" },
    ],
    fiches: [
      { t: "Modules ES", p: [
        "Un module, c'est un fichier. On y déclare explicitement ses dépendances avec import, et ce qu'on rend disponible avec export. Fini le temps des balises script empilées dans un ordre fragile et des variables globales qui s'écrasent les unes les autres.",
        "Cette explicitation change tout pour la maintenance : on voit d'un coup d'œil ce dont un fichier a besoin et ce qu'il fournit. Les outils peuvent alors analyser le graphe de dépendances, écarter le code mort et regrouper le tout pour le navigateur.",
      ] },
      { t: "async / await", p: [
        "Le réseau, le disque et la base de données prennent du temps. Plutôt que de bloquer le programme en les attendant, JavaScript travaille avec des promesses : un objet qui représente un résultat encore à venir.",
        "await suspend la fonction le temps que la promesse se résolve, puis reprend avec la valeur obtenue. Le code asynchrone se lit alors de haut en bas, comme du synchrone, tout en restant non bloquant. On l'entoure d'un try / catch pour gérer proprement les échecs.",
      ] },
      { t: "fetch", p: [
        "fetch lance une requête HTTP et renvoie immédiatement une promesse. Un premier await donne la réponse — son statut, ses en-têtes — mais pas encore son contenu.",
        "Un second await, sur response.json() par exemple, lit et décode le corps. Cette séparation en deux étapes surprend au début, mais elle reflète la réalité du réseau : l'en-tête arrive avant un corps qui peut être volumineux, voire diffusé en continu.",
      ] },
      { t: "npm et package.json", p: [
        "npm install ajoute une dépendance : il la télécharge dans node_modules et l'inscrit dans package.json, qui devient l'inventaire déclaré du projet.",
        "Un fichier de verrou fige les versions exactes installées, pour que l'équipe et le serveur obtiennent rigoureusement le même arbre de dépendances. Les scripts de package.json — start, dev, build — standardisent ensuite les commandes du projet.",
      ] },
    ],
  },
    {
    titre: "Concevoir une API",
    resume: "L'exemple fil rouge Lino : transformer un besoin réel en ressources et en endpoints cohérents et lisibles.",
    themes: ["ressources", "endpoints", "REST", "design"],
    liens: [
      { label: "Concevoir une API (Lino)", href: "/guides/tuto-conception-api" },
      { label: "Prise en main d'Express", href: "/guides/tuto-express" },
    ],
    fiches: [
      { t: "Partir des ressources", p: [
        "On commence par nommer les choses du domaine — les boîtes, les livres, les emprunts — avant de penser aux écrans ou aux boutons. Ce sont elles, les ressources de l'API.",
        "Cette modélisation oriente toute la suite : chaque ressource aura ses URL, ses représentations et ses relations. Partir des données plutôt que des actions évite une API en patchwork d'opérations ad hoc.",
      ] },
      { t: "Des endpoints qui parlent", p: [
        "Un bon endpoint exprime une intention par la combinaison d'un verbe et d'une ressource : POST /emprunts crée un emprunt, GET /boites/parc-laurier décrit une boîte.",
        "On évite les verbes dans l'URL, comme /faireUnEmprunt : la ressource est un nom, l'action vient du verbe HTTP. Cette régularité rend l'API devinable — qui en connaît une partie devine le reste.",
      ] },
      { t: "Les codes de statut", p: [
        "Le code de statut est la première phrase de la réponse. 201 annonce une création, 404 une ressource introuvable, 409 un conflit, 400 une requête mal formée.",
        "Bien choisis, ces codes racontent le résultat sans qu'on ait à lire le corps, et laissent le client réagir correctement. Les négliger — tout renvoyer en 200 avec un champ erreur — prive l'API du langage commun du Web.",
      ] },
      { t: "Une histoire cohérente", p: [
        "Une bonne API se parcourt comme un récit : les ressources s'enchaînent logiquement, les noms sont réguliers, les réponses sont prévisibles.",
        "Cette cohérence est un service rendu à celui qui l'utilise — souvent soi-même, plus tard. Elle se conçoit avant de coder, en écrivant la liste des endpoints comme on écrirait le plan d'un texte.",
      ] },
    ],
  },
