h2{font-family:var(--serif);font-size:1.5rem;font-weight:700;margin-top:3.5rem;margin-bottom:1rem;padding-bottom:.4rem;border-bottom:2px solid var(--c-accent);display:flex;align-items:baseline;gap:12px}
.h2-num{font-family:var(--mono);font-size:.82rem;font-weight:700;color:var(--c-accent);opacity:.5}
h3{font-size:1.08rem;font-weight:700;margin-top:2rem;margin-bottom:.6rem}
h4{font-size:.95rem;font-weight:700;color:var(--c-mid);margin-top:1.25rem;margin-bottom:.4rem}
p{margin-bottom:.8rem}
ul,ol{padding-left:1.25rem;margin-bottom:1rem}
li{margin-bottom:.3rem}
li::marker{color:var(--c-accent)}
code{font-family:var(--mono);font-size:.87em;background:var(--c-accent-b);color:var(--c-accent);padding:1px 5px;border-radius:3px}
pre{overflow-x:auto}
.code-block{background:#1e1e2e;color:#cdd6f4;border-radius:10px;padding:1.1rem 1.3rem;margin:1rem 0;font-family:var(--mono);font-size:.82rem;line-height:1.6;border:1px solid #313244;overflow-x:auto;white-space:pre}
.code-block code{background:none;color:inherit;padding:0;font-size:inherit}
.endpoint-table{width:100%;border-collapse:separate;border-spacing:0;margin:1rem 0;font-size:.86rem;border:1px solid var(--c-border);border-radius:8px;overflow:hidden}
.endpoint-table thead{background:var(--c-accent-b)}
.endpoint-table th{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--c-accent);padding:9px 12px;text-align:left;border-bottom:2px solid var(--c-accent)}
.endpoint-table td{padding:9px 12px;vertical-align:top;border-bottom:1px solid var(--c-border-s)}
.endpoint-table tr:last-child td{border-bottom:none}
.endpoint-table tbody tr:hover{background:var(--c-bg)}
.method{font-family:var(--mono);font-size:.72rem;font-weight:700;padding:2px 8px;border-radius:4px;white-space:nowrap}
.method--get{background:#dcfce7;color:#166534}
.method--post{background:#dbeafe;color:#1e40af}
.status-grid{display:flex;gap:10px;margin:1rem 0;flex-wrap:wrap}
.status-item{padding:8px 16px;border-radius:8px;font-size:.88rem;font-weight:500}
.status-item code{font-weight:700;font-size:.92em;margin-right:6px;background:none;color:inherit;padding:0}
.status-item--401{background:#fee2e2;color:#991b1b}
.status-item--403{background:#fef3c7;color:#92400e}
.status-item--200{background:#dcfce7;color:#166534}
.design-list{counter-reset:design;padding-left:0;list-style:none}
.design-list li{counter-increment:design;padding:10px 14px 10px 44px;position:relative;margin-bottom:8px;background:var(--c-surface);border:1px solid var(--c-border-s);border-radius:8px;font-size:.92rem}
.design-list li::before{content:counter(design);position:absolute;left:14px;top:10px;font-family:var(--mono);font-size:.78rem;font-weight:700;color:var(--c-accent);background:var(--c-accent-b);width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center}
.piste{display:flex;gap:18px;margin-bottom:2rem;padding-bottom:2rem;border-bottom:1px solid var(--c-border-s)}
.piste:last-child{border-bottom:none}
.piste__num{font-family:var(--serif);font-size:2rem;font-weight:800;color:var(--c-accent);opacity:.25;flex-shrink:0;width:36px;text-align:right;line-height:1.1;padding-top:4px}
.piste__body{flex:1;min-width:0}
.piste__body h4{margin-top:0}
.compare{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:1rem 0}
@media(max-width:640px){.compare{grid-template-columns:1fr}}
.compare__bad,.compare__good{border-radius:10px;overflow:hidden;border:1px solid var(--c-border-s)}
.compare__header{padding:8px 14px;font-weight:700;font-size:.82rem}
.compare__header--bad{background:#fef2f2;color:var(--c-red)}
.compare__header--good{background:#f0fdf4;color:var(--c-green)}
.compare__bad pre,.compare__good pre{margin:0;border-radius:0;border:none;background:#1e1e2e;color:#cdd6f4;padding:12px 14px;font-size:.82rem}
.compare__bad pre code,.compare__good pre code{background:none;color:inherit;padding:0}
.compare__bad p,.compare__good p{padding:10px 14px;font-size:.86rem;margin:0}
@media print{.hero{background:#134e4a!important;-webkit-print-color-adjust:exact}.toc{display:none}.content{max-width:none;padding:0 1rem}h2{break-after:avoid}.piste,.compare,table,pre,.design-list li{break-inside:avoid}}
</style>
</body>
</html>