<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--c-bg:#faf9f7;--c-surface:#fff;--c-border:#e0ded8;--c-border-s:#e8e6e1;--c-text:#1a1a2e;--c-mid:#44445a;--c-muted:#6b6b80;--c-dim:#9898ab;--c-accent:#0d9488;--c-accent-b:#f0fdfa;--c-accent-s:#ccfbf1;--c-warn:#d97706;--c-warn-b:#fffbeb;--c-blue:#3b6fca;--c-green:#2d8a4e;--c-red:#dc2626;--font:'DM Sans',system-ui,sans-serif;--serif:'Fraunces',Georgia,serif;--mono:'JetBrains Mono',Consolas,monospace}
