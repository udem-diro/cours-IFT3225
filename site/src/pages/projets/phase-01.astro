  </g>

  <!-- GET renversé : Collecte vers Téléphone -->
  <line x1="220" y1="75" x2="150" y2="75" stroke="#9898ab" stroke-width="1.5" marker-end="url(#ah)" />
  <text x="185" y="65" font-family="JetBrains Mono" font-size="10" fill="#6b6b80" text-anchor="middle">GET</text>

  <line x1="360" y1="75" x2="440" y2="75" stroke="#9898ab" stroke-width="1.5" marker-end="url(#ah)" />
